# SAP Document AI service credentials
# These values come from a SERVICE KEY of your Document AI instance (not from the CF API).
# Create the key in BTP: Instances and Subscriptions → your Document AI instance → Create (Service Keys).
# Do not commit .env; copy this file to .env and fill in your values.

# Document AI base URL and UAA (from the service key JSON)
URL=https://document-information-extraction-<region>.cpapps.<region>.hana.ondemand.com
CLIENT_ID=<from service key: uaa.clientid>
CLIENT_SECRET=<from service key: uaa.clientsecret>
UAADOMAIN=https://<from service key: uaa.url>
